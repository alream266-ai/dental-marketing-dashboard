ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_PLACES_API_KEY=optional-for-google-reviews

# Persistent database. On Vercel/serverless you MUST set this to a hosted
# Postgres URL (e.g. Neon) — otherwise it defaults to SQLite, which does not
# persist between serverless invocations. Example:
# DATABASE_URL=postgresql://user:password@host/dbname
DATABASE_URL=

# Optional: remote headless-browser API for full rendered-DOM SEO audits on
# serverless (Vercel), where local Chromium can't run. Get a token from
# browserless.io. When unset, audits fall back to static HTML on Vercel.
BROWSERLESS_API_KEY=
# Override only if self-hosting Browserless; default is the cloud endpoint.
# BROWSERLESS_URL=https://production-sfo.browserless.io
